<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/live_card_item_margin"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:stateListAnimator="@animator/card_focus_animator"
    android:paddingBottom="@dimen/live_card_bottom_padding">

    <!-- Foreground focused border -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/card_focused_background"
        app:layout_constraintTop_toTopOf="@id/cover_container"
        app:layout_constraintBottom_toBottomOf="@id/cover_container"
        app:layout_constraintStart_toStartOf="@id/cover_container"
        app:layout_constraintEnd_toEndOf="@id/cover_container"
        android:elevation="4dp" />

    <!-- 封面区域 (圆角 16:9) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cover_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="16:9"
        app:cardCornerRadius="@dimen/live_card_corner_radius"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#2b2c38">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- 直播封面 -->
            <ImageView
                android:id="@+id/cover_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@android:color/darker_gray" />

            <!-- 渐变遮罩层 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/live_card_gradient_height"
                android:layout_alignParentBottom="true"
                android:background="@drawable/gradient_mask"
                android:alpha="0.8" />

            <!-- 底部左侧：主播信息 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentBottom="true"
                android:layout_alignParentStart="true"
                android:layout_marginStart="@dimen/live_card_info_horizontal_margin"
                android:layout_marginBottom="@dimen/live_card_info_bottom_margin"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/anchor_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="@dimen/live_card_anchor_text_size"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/viewer_count_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentBottom="true"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="@dimen/live_card_info_horizontal_margin"
                android:layout_marginBottom="@dimen/live_card_info_bottom_margin"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="@dimen/live_card_info_icon_size"
                    android:layout_height="@dimen/live_card_info_icon_size"
                    android:src="@drawable/ic_lucide_eye"
                    android:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/viewer_count_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/live_card_info_text_spacing"
                    android:text="10.5万"
                    android:textColor="@android:color/white"
                    android:textSize="@dimen/live_card_viewer_text_size"
                    android:textStyle="bold" />
            </LinearLayout>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- 直播间标题 -->
    <TextView
        android:id="@+id/room_title"
        android:layout_width="0dp"
        android:layout_height="@dimen/live_card_title_height"
        app:layout_constraintTop_toBottomOf="@id/cover_container"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/live_card_title_margin_top"
        android:layout_marginHorizontal="@dimen/live_card_title_horizontal_margin"
        android:gravity="top"
        android:includeFontPadding="false"
        android:textColor="@android:color/white"
        android:textSize="@dimen/live_card_title_text_size"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- 隐藏的原有分区标签 -->
    <TextView
        android:id="@+id/area_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/room_title"
        app:layout_constraintStart_toStartOf="parent"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
