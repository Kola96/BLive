<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1d1e23">

    <!-- Header区域 -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#1a1a1a"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:gravity="center_vertical"
        android:elevation="4dp"
        android:focusable="true"
        android:focusableInTouchMode="true">

        <!-- 左侧Logo/名称 -->
        <ImageView
            android:id="@+id/app_logo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:id="@+id/main_tab_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/main_tab_following"
                android:layout_width="120dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="关注"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/main_tab_background"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusRight="@id/main_tab_recommend"
                android:nextFocusDown="@id/main_grid" />

            <TextView
                android:id="@+id/main_tab_recommend"
                android:layout_width="120dp"
                android:layout_height="44dp"
                android:layout_marginStart="16dp"
                android:gravity="center"
                android:text="推荐"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#B0B0B0"
                android:background="@drawable/main_tab_background"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusLeft="@id/main_tab_following"
                android:nextFocusDown="@id/main_grid" />
        </LinearLayout>

        <!-- 右侧区域：用户信息 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginLeft="20dp">

            <!-- 用户信息区域 -->
            <LinearLayout
                android:id="@+id/user_info_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusDown="@+id/main_grid">
                
                <!-- 用户昵称 -->
                <TextView
                    android:id="@+id/user_nickname"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginRight="10dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:gravity="right"
                    android:padding="4dp"
                    android:nextFocusLeft="@id/main_tab_recommend"
                    android:focusable="false"
                    android:focusableInTouchMode="false" />
                
                <!-- 用户头像区域 -->
                <FrameLayout
                    android:id="@+id/user_avatar_container"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusLeft="@+id/user_nickname"
                    android:nextFocusDown="@+id/main_grid"
                    android:background="@drawable/avatar_focused_background">

                    <androidx.cardview.widget.CardView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#1a1a1a">

                        <ImageView
                            android:id="@+id/user_avatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:background="@android:color/darker_gray" />
                    </androidx.cardview.widget.CardView>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 内容区域 -->
    <androidx.leanback.widget.VerticalGridView
        android:id="@+id/main_grid"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_container"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:background="#1d1e23"
        android:overScrollMode="never"
        android:nextFocusUp="@+id/user_avatar_container" />

    <LinearLayout
        android:id="@+id/live_list_loading_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_container"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:focusable="false"
        android:focusableInTouchMode="false">

        <ProgressBar
            android:id="@+id/live_list_loading_progress"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminate="true" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/live_list_empty_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_container"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:focusable="false"
        android:focusableInTouchMode="false">

        <TextView
            android:id="@+id/live_list_empty_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="当前没有正在直播的直播间"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:layout_marginBottom="24dp" />

        <ImageButton
            android:id="@+id/live_list_empty_refresh_button"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/state_refresh_button_background"
            android:src="@drawable/ic_refresh"
            android:scaleType="center"
            android:tint="#E0E0E0"
            android:contentDescription="刷新"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusUp="@+id/user_avatar_container" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/live_list_error_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_container"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:focusable="false"
        android:focusableInTouchMode="false">

        <TextView
            android:id="@+id/live_list_error_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="加载失败, 请检查你的网络状况"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:layout_marginBottom="24dp" />

        <ImageButton
            android:id="@+id/live_list_error_refresh_button"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/state_refresh_button_background"
            android:src="@drawable/ic_refresh"
            android:scaleType="center"
            android:tint="#E0E0E0"
            android:contentDescription="刷新"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusUp="@+id/user_avatar_container" />
    </LinearLayout>

    <!-- 未登录时显示的中央登录按钮 -->
    <LinearLayout
        android:id="@+id/login_button_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_container"
        android:gravity="center"
        android:visibility="gone"
        android:orientation="vertical"
        android:focusable="true"
        android:focusableInTouchMode="true">

        <FrameLayout
            android:id="@+id/login_button"
            android:layout_width="300dp"
            android:layout_height="80dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:background="@drawable/login_button_focused_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="4dp"
                android:gravity="center"
                android:orientation="vertical"
                android:background="#FF4081">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击登录"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</RelativeLayout>
