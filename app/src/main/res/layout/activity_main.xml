<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#1d1e23">

    <!-- 左侧边栏 -->
    <LinearLayout
        android:id="@+id/main_sidebar_container"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:background="#181820"
        android:orientation="vertical"
        android:paddingVertical="40dp"
        android:elevation="4dp">

        <!-- Logo -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="64dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerCrop" />
        </FrameLayout>

        <!-- 标签页容器 -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal">

            <!-- 焦点滑块 -->
            <View
                android:id="@+id/tab_focus_slider"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:background="@drawable/main_tab_focus_slider"
                android:visibility="invisible" />

            <LinearLayout
                android:id="@+id/main_tab_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:layout_gravity="center_horizontal">

            <FrameLayout
                android:id="@+id/tab_login"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/main_tab_background"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lucide_user"
                    android:tint="@color/tab_text_color"
                    android:duplicateParentState="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="登录"
                    android:textSize="@dimen/main_tab_text_size"
                    android:textStyle="bold"
                    android:textColor="@color/tab_text_color"
                    android:visibility="invisible"
                    android:duplicateParentState="true" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/tab_following"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/main_tab_background"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lucide_heart"
                    android:tint="@color/tab_text_color"
                    android:duplicateParentState="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="关注"
                    android:textSize="@dimen/main_tab_text_size"
                    android:textStyle="bold"
                    android:textColor="@color/tab_text_color"
                    android:visibility="invisible"
                    android:duplicateParentState="true" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/tab_recommend"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/main_tab_background"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lucide_home"
                    android:tint="@color/tab_text_color"
                    android:duplicateParentState="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="推荐"
                    android:textSize="@dimen/main_tab_text_size"
                    android:textStyle="bold"
                    android:textColor="@color/tab_text_color"
                    android:visibility="invisible"
                    android:duplicateParentState="true" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/tab_partition"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/main_tab_background"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lucide_layout_grid"
                    android:tint="@color/tab_text_color"
                    android:duplicateParentState="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="分区"
                    android:textSize="@dimen/main_tab_text_size"
                    android:textStyle="bold"
                    android:textColor="@color/tab_text_color"
                    android:visibility="invisible"
                    android:duplicateParentState="true" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/tab_mine"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/main_tab_background"
                android:focusable="true"
                android:focusableInTouchMode="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lucide_user"
                    android:tint="@color/tab_text_color"
                    android:duplicateParentState="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="我的"
                    android:textSize="@dimen/main_tab_text_size"
                    android:textStyle="bold"
                    android:textColor="@color/tab_text_color"
                    android:visibility="invisible"
                    android:duplicateParentState="true" />
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>

    <!-- 右侧主内容区 -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:padding="30dp">

        <!-- 1. 登录页容器 -->
        <RelativeLayout
            android:id="@+id/login_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:layout_width="400dp"
                android:layout_height="500dp"
                android:layout_centerInParent="true"
                app:cardBackgroundColor="#23242A"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="扫码登录"
                        android:textColor="#FFFFFF"
                        android:textSize="@dimen/login_title_text_size"
                        android:textStyle="bold"
                        android:layout_marginBottom="32dp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="220dp"
                        android:layout_height="220dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <ImageView
                            android:id="@+id/qr_code_image"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="12dp"
                            android:scaleType="centerCrop" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/status_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="请使用 哔哩哔哩 客户端扫码登录"
                        android:textColor="#A0A0A0"
                        android:textSize="@dimen/login_status_text_size"
                        android:layout_marginTop="24dp" />

                    <TextView
                        android:id="@+id/countdown_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#A0A0A0"
                        android:textSize="@dimen/login_countdown_text_size"
                        android:layout_marginTop="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </RelativeLayout>

        <!-- 2. "我的"页容器 -->
        <LinearLayout
            android:id="@+id/mine_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="我的"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/main_page_title_text_size"
                android:textStyle="bold"
                android:layout_marginBottom="32dp" />

            <!-- 用户信息卡片 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#23242A"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="32dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#1a1a1a">

                        <ImageView
                            android:id="@+id/user_avatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:background="@android:color/darker_gray" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="24dp">

                        <TextView
                            android:id="@+id/user_nickname"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="@dimen/main_user_nickname_text_size"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:id="@+id/user_badge_container"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:visibility="gone">
                            <TextView
                                android:id="@+id/user_vip_tag"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="大会员"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:background="@drawable/rounded_tag"
                                android:backgroundTint="#FFFB7299"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:layout_marginEnd="8dp" />
                            <TextView
                                android:id="@+id/user_level_tag"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LV6"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:background="@drawable/rounded_tag"
                                android:backgroundTint="#334C6680"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 操作按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/btn_settings"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:background="@drawable/mine_settings_button_background">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginHorizontal="20dp"
                        android:gravity="center"
                        android:text="偏好设置"
                        android:textColor="#FFFFFF"
                        android:textSize="@dimen/main_action_button_text_size"
                        android:textStyle="bold" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/btn_logout"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:background="@drawable/mine_logout_button_background">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginHorizontal="20dp"
                        android:gravity="center"
                        android:text="退出登录"
                        android:textColor="#FF8080"
                        android:textSize="@dimen/main_action_button_text_size"
                        android:textStyle="bold" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 3. 网格列表容器 (推荐/关注 共用) -->
        <LinearLayout
            android:id="@+id/grid_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:id="@+id/grid_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="为您推荐"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/main_page_title_text_size"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.leanback.widget.VerticalGridView
                    android:id="@+id/main_grid"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:overScrollMode="never" />

                <!-- 状态视图 -->
                <LinearLayout
                    android:id="@+id/live_list_loading_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <ProgressBar
                        android:id="@+id/live_list_loading_progress"
                        style="?android:attr/progressBarStyleLarge"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:indeterminate="true" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/live_list_empty_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:id="@+id/live_list_empty_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="当前没有正在直播的直播间"
                        android:textColor="@android:color/white"
                        android:textSize="24sp"
                        android:layout_marginBottom="24dp" />
                    <ImageButton
                        android:id="@+id/live_list_empty_refresh_button"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/state_refresh_button_background"
                        android:src="@drawable/ic_refresh"
                        android:scaleType="center"
                        android:tint="#E0E0E0"
                        android:contentDescription="刷新"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/live_list_error_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:id="@+id/live_list_error_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="加载失败, 请检查你的网络状况"
                        android:textColor="@android:color/white"
                        android:textSize="24sp"
                        android:layout_marginBottom="24dp" />
                    <ImageButton
                        android:id="@+id/live_list_error_refresh_button"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/state_refresh_button_background"
                        android:src="@drawable/ic_refresh"
                        android:scaleType="center"
                        android:tint="#E0E0E0"
                        android:contentDescription="刷新"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
