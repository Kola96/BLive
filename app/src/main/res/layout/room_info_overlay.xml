<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/room_info_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000"
    android:visibility="gone"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <!-- Top Bar: Room Title -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/room_info_gradient_top">

        <TextView
            android:id="@+id/room_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- Bottom Bar: Anchor Name + Follow Button -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="24dp"
        android:background="@drawable/room_info_gradient_bottom">

        <!-- Anchor Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/label_anchor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="主播"
                android:textColor="#AAFFFFFF"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/anchor_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Right Side: Follow Button & Hint -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Follow Button Container -->
            <FrameLayout
                android:id="@+id/follow_button_container"
                android:layout_width="120dp"
                android:layout_height="48dp">

                <!-- Fill Animation View (at the bottom) -->
                <com.blive.tv.ui.play.FollowButtonView
                    android:id="@+id/follow_animation_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone"/>

                <!-- Text and Icon (on top of fill animation) -->
                <LinearLayout
                    android:id="@+id/follow_content"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/follow_icon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_lucide_heart"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/follow_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="关注"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"/>
                </LinearLayout>

            </FrameLayout>

            <!-- Hint Text: Long press to toggle -->
            <TextView
                android:id="@+id/hint_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="长按确认键关注"
                android:textColor="#88FFFFFF"
                android:textSize="14sp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
